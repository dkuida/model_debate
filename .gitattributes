# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.env       text eol=lf
*.sh        text eol=lf
*.ps1       text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.dll       binary
*.exe       binary

{
  "AnthropicModel":     "claude-sonnet-4-6",
  "OpenAiModel":        "gpt-4.1-mini",
  "TurnTimeoutSeconds": 60,
  "MaxTurns":           30,
  "LogDirectory":       "",
  "Serilog": {
    "MinimumLevel": {
      "Default":   "Debug"
      
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:s} [{Level:u3}] [ThreadId: {ThreadId}] {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Warning",
          "outputTemplate": "{Timestamp:s} [{Level:u3}] [ThreadId: {ThreadId}] {Message}{NewLine}{Exception}",
          "retainedFileCountLimit": 5
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "TechicalLogger"
    }
  },
  "DebateLogger" :{
    "MinimumLevel": {
      "Default":   "Information"
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "{@t:s}{#if From = 'Claude'}\u001b[25m{#else if From = 'GPT'}\u001b[32m{#else}\u001b[33m{#end}{@m}\u001b[0m\n"
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/chat-.txt",
          "rollingInterval": "Day",

          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "{Timestamp:s}{Message}",
          "retainedFileCountLimit": 30
        }
      }
    ],
   
    "Properties": {
      "Application": "DebateLogger"
    }
  }
}
